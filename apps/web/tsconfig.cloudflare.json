{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "noEmit": false,
    "outDir": "./.cache/tsc",
    "paths": {
      "~/*": ["./app/*"]
    }
  },
  "include": ["app/**/*", "workers/**/*", "worker-configuration.d.ts"]
}
