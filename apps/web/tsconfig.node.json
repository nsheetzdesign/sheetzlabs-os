{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": false,
    "outDir": "./.cache/tsc"
  },
  "include": ["vite.config.ts", "react-router.config.ts"]
}
