{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sheetz Labs OS",
  "identifier": "com.sheetzlabs.os",
  "version": "1.0.0",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "https://app.sheetzlabs.com",
    "frontendDist": "https://app.sheetzlabs.com"
  },
  "app": {
    "windows": [
      {
        "title": "Sheetz Labs OS",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["remote-access"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Sheetz Labs",
    "category": "Productivity",
    "shortDescription": "AI-native founder operating system",
    "longDescription": "Sheetz Labs OS is an AI-powered operating system for solo founders and venture studios. Manage ventures, pipeline, relationships, content, and more with AI agents.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      },
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
